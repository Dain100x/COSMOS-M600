[gcode_macro M600]
description: filament swap
variable_old_temp: 0
gcode:
    {% set print_temp = printer.extruder.target|float %}

    SAVE_GCODE_STATE NAME=M600_state
    PAUSE

    # --- STORE PRINT TEMP ---
    SET_GCODE_VARIABLE MACRO=M600 VARIABLE=old_temp VALUE={print_temp}

    {% if "xyz" not in printer.toolhead.homed_axes %}
        G28
    {% endif %}

    G90
    G1 Z5 F3000
    MOVE_TO_TRAY

    M109 S{print_temp}

    UNLOAD_FILAMENT

    RESPOND TYPE=command MSG="action:prompt_begin Filament Change"
    RESPOND TYPE=command MSG="action:prompt_text Insert filament and press LOAD"
    RESPOND TYPE=command MSG="action:prompt_footer_button Load|FILAMENT_LOAD"
    RESPOND TYPE=command MSG="action:prompt_show"
